<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.khedron83.Quill</id>
  <name>Quill</name>
  <summary>Task manager with Nextcloud CalDAV sync</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <description>
    <p>
      Quill is a desktop task manager that syncs with your Nextcloud instance via CalDAV.
      Manage your tasks and to-do lists from your desktop.
    </p>
    <ul>
      <li>Sync tasks with Nextcloud via CalDAV</li>
      <li>Create, edit, and complete tasks</li>
      <li>Due dates and priorities</li>
      <li>Works offline with local cache</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.khedron83.Quill.desktop</launchable>

  <url type="homepage">https://github.com/khedron83/Quill</url>
  <url type="bugtracker">https://github.com/khedron83/Quill/issues</url>

  <provides>
    <binary>quill</binary>
  </provides>

  <releases>
    <release version="1.0.0" date="2025-01-01">
      <description><p>Initial release.</p></description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>
</component>
